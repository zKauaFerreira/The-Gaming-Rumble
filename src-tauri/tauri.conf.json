{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GamingRumble",
  "version": "1.0.5",
  "identifier": "com.gamingrumble.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gaming Rumble",
        "width": 820,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["gaming-rumble"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2QTk4MkRBNDhGNTVCNTYKUldSV1cvVkkyb0twNWllbSs1aUVVNjNRMFhZOHdZejM0VmY5ZWdRbjc0UENLMEVHNDBrYTc5WEIK",
      "endpoints": [
        "https://github.com/zKauaFerreira/The-Gaming-Rumble/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/bin/aria2c.exe": "bin/aria2c.exe",
      "resources/7-ZIP": "7-ZIP"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
